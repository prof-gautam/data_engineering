   "outputs": [],
   "source": [
    "def get_null_columns(df):\n",
    "    columns_with_nulls= []\n",
    "    for column in df.columns:\n",
    "        if df.filter(col(column).isNull()).count()>0:\n",
    "            columns_with_nulls.append(column)\n",
    "    return columns_with_nulls"
   ]
  }
